
AWEN_APP_NAME="AWEN"
AWEN_APP_FAVICON="" # optional
AWEN_APP_HOST="https://example.com"
AWEN_APP_PREFIX="/em" # optional

# *gcore.json can be set as file path or http(s) url
AWEN_GCORE="/awen-config/gcore.json"
AWEN_GCORE_RAMEN="/awen-config/ramen.gcore.json"
#AWEN_GCORE_RAMEN="https://raw.githubusercontent.com/THM-Graphs/ATAG-Editor-Guidlines/refs/heads/main/ramen.gcore.json"
#AWEN_GCORE_PROJECT="/awen-config/regesta-imperii.gcore.json"
AWEN_GCORE_PROJECT="/awen-config/abbw.gcore.json"

# Connection to the neo4j instance
AWEN_DB_HOST="example.com"
AWEN_DB_PASSWORD="neo4jPass"
AWEN_DB_PORT=7687
AWEN_DB_USER="neo4j"
AWEN_DB_SCHEME="neo4j" # "neo4j+s", "bolt", "bolt+s", usw.
AWEN_DB_NAME="neo4j" # optional | default: "neo4j"
